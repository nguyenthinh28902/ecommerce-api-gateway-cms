@model string 

@{
    ViewData["Title"] = "Lỗi đăng nhập";
    var errorMessage = Model ?? "Thông tin đăng nhập không chính xác hoặc tài khoản đã bị khóa.";
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-[#fff5f5] to-[#ffffff] font-sans">
    
    <div class="bg-white p-10 rounded-[40px] shadow-2xl w-full max-w-[500px] text-center border-t-8 border-[#ff5f57]">
        
        <div class="flex justify-center mb-6">
            <div class="bg-[#fff5f5] p-5 rounded-full">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-[#ff5f57]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 15c-.77 1.333.192 3 1.732 3z" />
                </svg>
            </div>
        </div>

        <h1 class="text-[#ff5f57] text-3xl font-extrabold mb-2 tracking-tight">Đăng nhập thất bại!</h1>
        <p class="text-gray-500 mb-8 px-4">@errorMessage</p>

        <div class="bg-[#fff9f9] border border-[#ffebeb] rounded-3xl p-6 mb-8 text-left">
            <h3 class="text-sm font-bold text-gray-700 mb-2 uppercase tracking-wider">Hướng dẫn khắc phục:</h3>
            <ul class="text-sm text-gray-600 space-y-2 list-disc ml-5">
                <li>Kiểm tra lại <b>Mã người dùng (ID)</b>.</li>
                <li>Đảm bảo phím <b>Caps Lock</b> đang tắt khi nhập mật khẩu.</li>
                <li>Nếu quên mật khẩu, vui lòng liên hệ quản trị viên hệ thống.</li>
            </ul>
        </div>

        <div class="space-y-3">
            <a href="@Url.Action("Index", "Account")"
               class="w-full bg-[#ff5f57] hover:bg-[#ee4f47] text-white font-bold py-4 rounded-xl flex items-center justify-center gap-2 transition duration-300 shadow-lg shadow-red-100">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 15l-3-3m0 0l3-3m-3 3h8M3 12a9 9 0 1118 0 9 9 0 01-18 0z" />
                </svg>
                Quay lại trang đăng nhập
            </a>
            
            <a href="mailto:support@ecommerce.com" class="block text-sm text-gray-400 hover:text-gray-600 transition underline">
                Liên hệ hỗ trợ kỹ thuật
            </a>
        </div>

        <div class="mt-10">
            <p class="text-[10px] text-gray-400 font-bold tracking-widest uppercase">
                © 2026 Ecommerce CMS - Security Module
            </p>
        </div>
    </div>
</div>